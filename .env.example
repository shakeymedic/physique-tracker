# Copy this to .env.local and fill in with values from Firebase console
# (Project settings → Your apps → SDK setup and configuration)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Cloud Messaging VAPID key (for push notifications)
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Generate key pair
VITE_FIREBASE_VAPID_KEY=

# Google OAuth Client ID (for Google Drive backup feature)
# Google Cloud Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=
